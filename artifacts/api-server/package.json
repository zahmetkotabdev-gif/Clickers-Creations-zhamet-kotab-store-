    "dotenv": "^17.4.2",
    "drizzle-orm": "*",
    "express": "^5",
    "express-rate-limit": "^8.4.0",
    "helmet": "^8.1.0",
    "pino": "^9",
    "pino-http": "^10"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "*",
    "esbuild": "^0.27.3",
